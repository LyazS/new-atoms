OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Pro/MiniMaxAI/MiniMax-M2.5
OPENAI_TIMEOUT=600
AGENT_MAX_ITERATIONS=10
LOG_LEVEL=INFO
LOG_FILE_PATH=
LOG_FILE_ROTATION=10 MB
LOG_FILE_RETENTION=7 days

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

CORS_ALLOW_ORIGINS=["*"]
DATABASE_URL=sqlite:///data/app.db
AUTH_SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=120
PUBLISH_WORKSPACE_ROOT=data/published-workspaces
PUBLISH_ARTIFACT_ROOT=data/published-artifacts
PUBLISH_BASE_URL=http://127.0.0.1:8000
PUBLISH_BUILD_TIMEOUT_SECONDS=240
PUBLISH_MAX_CONCURRENT_BUILDS=2
PUBLISH_LOG_LIMIT=50000
